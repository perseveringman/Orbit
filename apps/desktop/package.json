{
  "name": "@orbit/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Orbit Desktop Electron 宿主脚手架",
  "type": "module",
  "main": "dist/main/index.js",
  "types": "dist/shared/contracts.d.ts",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --ext .ts,.tsx src",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"import('node:fs/promises').then(({ rm }) => rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@orbit/feature-workbench": "workspace:*",
    "@orbit/platform-electron": "workspace:*",
    "@orbit/ui-dom": "workspace:*",
    "electron": "^35.0.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-react": "^4.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.1"
  }
}
