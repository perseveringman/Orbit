{
  "name": "@orbit/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Orbit 零知识服务端宿主（Hono host）",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "clean": "rm -rf dist",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.7.8",
    "@orbit/api-types": "workspace:*",
    "@orbit/server-core": "workspace:*",
    "@orbit/server-infra": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
