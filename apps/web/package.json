{
  "name": "@orbit/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Orbit Web Browser host，负责挂载共享 DOM workbench 与浏览器平台适配层",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage .vite"
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@orbit/feature-workbench": "workspace:*",
    "@orbit/platform-web": "workspace:*",
    "@orbit/reader-resolvers": "workspace:*",
    "@orbit/ui-dom": "workspace:*",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.1"
  }
}
