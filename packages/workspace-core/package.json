{
  "name": "@orbit/workspace-core",
  "version": "0.1.0",
  "private": true,
  "description": "Orbit workspace 契约与视图上下文协议",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @orbit/domain build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @orbit/domain build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run ./tests/index.test.ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@orbit/domain": "workspace:*"
  }
}
